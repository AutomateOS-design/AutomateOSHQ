# AutomateOS Production Configuration
# Copy to .env and adjust values

# Admin login password (change this in production!)
ADMIN_PASSWORD=automateos-admin-2026

# Server port
PORT=3000

# Session secret (auto-generated if empty; set a fixed value for multi-instance)
SESSION_SECRET=

# Team-db binary path (leave default unless customized)
TEAM_DB_BIN=team-db
